<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/availability"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page"
    tools:context=".HomeActivity">

    <!-- Top Navigation Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topNavBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_700"
        android:paddingHorizontal="12dp"
        android:elevation="6dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:text="@string/username"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:contentDescription="@string/menu"
            android:src="@android:drawable/ic_menu_more"
            app:tint="@android:color/white"
            tools:ignore="TouchTargetSizeCheck" />
    </androidx.appcompat.widget.Toolbar>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Hidden Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/logoutButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:backgroundTint="@color/primary_700"
                    android:textColor="#FFFFFF"
                    android:text="@string/log_out" />

                <Button
                    android:id="@+id/updateInfoButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:backgroundTint="@color/primary_700"
                    android:textColor="#FFFFFF"
                    android:text="@string/update_patient_information" />
            </LinearLayout>

            <!-- Welcome Message -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@drawable/rounded_card_bg"
                android:text="@string/welcome_to_q_now_your_one_stop_queueing_and_appointment_assistant"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Quick Actions -->
            <LinearLayout
                android:id="@+id/quickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnJoinQueue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_700"
                    android:textColor="#FFFFFF"
                    android:text="@string/join_queue"
                    android:textSize="12sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnBookAppointment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_700"
                    android:textColor="#FFFFFF"
                    android:text="@string/book_appointment"
                    android:textSize="12sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnMyRequests"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/primary_700"
                    android:textColor="#FFFFFF"
                    android:text="@string/my_requests"
                    android:textSize="12sp"
                    android:padding="0dp" />

                <Button
                    android:id="@+id/btnInbox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/primary_700"
                    android:textColor="#FFFFFF"
                    android:text="Inbox"
                    android:textSize="12sp"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Active Queues Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/blue_section_bg"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvActiveQueues"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/active_queues"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:elevation="2dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvActiveQueues"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:clipToPadding="false"
                        android:padding="4dp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Upcoming Appointments -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/blue_section_bg"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvUpcomingAppointments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upcoming Appointments"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:elevation="2dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvUpcomingAppointments"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:clipToPadding="false"
                        android:padding="4dp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Notifications (replaces Awaiting Arrival card) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/blue_section_bg"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notifications"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:elevation="2dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvNotifications"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:clipToPadding="false"
                        android:padding="4dp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="@drawable/blue_section_bg"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvNearbyCenters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recently_visited_centers"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingBottom="8dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@android:color/white"
                    android:elevation="2dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentlyVisited"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:clipToPadding="false"
                        android:padding="4dp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
