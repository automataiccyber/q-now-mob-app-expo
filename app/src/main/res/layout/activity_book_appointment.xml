<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book Appointment"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp"
            android:background="#FAFAFA"
            android:elevation="2dp"
            android:textColor="@android:color/black"
            android:layout_marginBottom="20dp" />

        <!-- Card Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="4dp"
            android:clipToOutline="true"
            android:backgroundTintMode="src_in">

            <!-- Select Service -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Service"
                android:textSize="15sp"
                android:paddingBottom="6dp"
                android:textColor="#222222" />

            <Spinner
                android:id="@+id/spnServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:drawable/btn_dropdown"
                android:padding="8dp" />

            <!-- Select Time Slots -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Time Slots"
                android:textSize="15sp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"
                android:textColor="#222222" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scroll horizontally to see more dates. Tap slots to select."
                android:textSize="12sp"
                android:textColor="#666666"
                android:paddingBottom="8dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FAFAFA"
                android:scrollbars="horizontal">

                <TableLayout
                    android:id="@+id/tableSchedule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:divider="@android:drawable/divider_horizontal_bright"
                    android:showDividers="middle" />

            </HorizontalScrollView>

            <!-- Reason -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reason"
                android:textSize="15sp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"
                android:textColor="#222222" />

            <EditText
                android:id="@+id/etReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Reason for appointment"
                android:inputType="textMultiLine"
                android:background="@android:drawable/edit_text"
                android:minLines="3"
                android:padding="10dp"
                android:textColor="#111111"
                android:textColorHint="#888888" />
        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/btnRequest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Request Appointment"
            android:backgroundTint="@color/primary_700"
            android:textColor="#F0F0F0"
            android:padding="12dp"
            android:layout_marginTop="8dp"
            android:elevation="3dp" />

    </LinearLayout>
</ScrollView>
