<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_qnow_launcher"
        android:roundIcon="@mipmap/ic_qnow_launcher"
        android:label="Q-Now"
        android:supportsRtl="true"
        android:theme="@style/Theme.SIGNIN"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".Resetpass"
            android:exported="true">
        </activity>
        <activity
            android:name=".Signup"
            android:exported="true">
        </activity>
        <activity
            android:name=".HomeActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".PatientInfo"
            android:exported="true">
        </activity>
        <activity
        android:name=".JoinQueueActivity"
        android:exported="true">
        </activity>
        <activity
            android:name=".JoinConfrimActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".SearchEstablishmentActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".BookAppointmentActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".MyRequestsActivity"
            android:exported="true">
        </activity>
        <activity
            android:name=".InboxActivity"
            android:exported="true">
        </activity>

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
